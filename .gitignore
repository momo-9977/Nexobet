cat > .gitignore <<'EOF'
# Node modules
/node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (do NOT commit secrets)
.env
.env.*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Uploads and runtime data (do NOT commit)
uploads/
data/
*.sqlite
*.db

# Logs
logs/
*.log
debug.log

# Build outputs
dist/
build/
.next/
.out/
.cache/
.tmp/

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Dependency directories
bower_components/

# Coverage and test output
coverage/
jest/coverage/

# Mac / Windows
*.swp
*.swo

# SSH keys, certs, and secrets
*.pem
*.key
*.crt
*.p12
id_rsa
id_rsa.pub

# Misc
.env.backup
*.local
*.history

# Optional: if you add Docker / compose files you may want to ignore credentials
docker-compose.override.yml
EOF