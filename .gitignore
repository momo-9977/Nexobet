# Node modules
/node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (do NOT commit secrets)
.env
.env.*.local
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.backup

# Uploads and runtime data (do NOT commit)
uploads/
data/
# keep sample files if you want, but not real data
# data/sample-*.json

# Databases / sqlite
*.sqlite
*.db

# Logs
logs/
*.log
debug.log
pids/
*.pid
*.seed
*.pid.lock

# Build outputs
dist/
build/
.next/
.out/
.cache/
.tmp/

# Coverage and test output
coverage/
jest/coverage/

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
.history/

# Dependency directories
bower_components/

# Temp
tmp/
.temp/
*.tmp

# SSH keys, certs, and secrets
*.pem
*.key
*.crt
*.p12
id_rsa
id_rsa.pub

# Misc
*.swp
*.swo
*.local
*.history

# Docker overrides (optional)
docker-compose.override.yml

# NOTE: package-lock.json is usually committed for apps for reproducible installs.
# If you intentionally want to ignore lockfiles, uncomment the next line:
# package-lock.json